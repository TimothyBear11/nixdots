#!/usr/bin/env bash
# shell-switch - Simple shell switcher for Hyprland
# Supports: Ambxst, Caelestia, DMS, Noctalia

set -eo pipefail

# Shell data - parallel arrays
shells=("ambxst" "caelestia" "dms" "noctalia")
names=("Ambxst" "Caelestia" "DMS" "Noctalia")
launch_cmds=("ambxst" "caelestia-shell -d" "dms run" "noctalia-shell")
patterns=(".quickshell-wra" ".quickshell-wra" ".quickshell-wra" ".quickshell-wra")
quit_cmds=("pkill -fi ambxst" "pkill -fi caelestia" "pkill -fi dms" "pkill -fi noctalia")

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log() { echo -e "${GREEN}[INFO]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }

# Get shell index by name
get_shell_index() {
    local name="$1"
    for i in "${!shells[@]}"; do
        if [[ "${shells[$i]}" == "$name" ]]; then
            echo "$i"
            return 0
        fi
    done
    echo "-1"
}

# 1. Simplified Detection: Just see if ANY quickshell is running
detect_shell() {
    if pgrep -f ".quickshell-wra" &>/dev/null; then
        echo "active-shell" # We don't need to know which one, just that one exists
    else
        echo ""
    fi
}

# 2. The Universal Kill: This actually works (as proven by your manual test)
kill_shell() {
    log "Clearing existing shell interface..."

    # Use the command that worked manually
    # We use || true so the script doesn't crash if nothing is found
    kill -9 $(pgrep -f ".quickshell-wra") 2>/dev/null || true
    pkill -9 -f "quickshell" 2>/dev/null || true

    sleep 0.5
}

# 3. Updated Main: Remove the index check for 'current'
main() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: shell-switch <ambxst|caelestia|dms|noctalia>"
        exit 1
    fi

    local new_shell="$1"
    local new_idx
    new_idx=$(get_shell_index "$new_shell")

    if [[ "$new_idx" == "-1" ]]; then
        error "Unknown shell: $new_shell"
        exit 1
    fi

    # Always kill whatever is currently there
    kill_shell

    update_config "$new_idx"
    start_shell "$new_idx"

    log "Switched to ${names[$new_idx]}!"
}
# Start a shell
start_shell() {
    local idx="$1"
    local shell="${shells[$idx]}"
    log "Starting $shell..."
    ${launch_cmds[$idx]} &>/dev/null &
    sleep 1
    log "Started $shell"
}

# Update Hyprland config
update_config() {
    local idx="$1"
    local conf="$HOME/.config/hypr/hyprland.conf"

    # Comment out all
    for i in "${!shells[@]}"; do
        sed -i "s/^exec-once = ${launch_cmds[$i]}/#exec-once = ${launch_cmds[$i]}/" "$conf"
    done

    # Uncomment target
    sed -i "s/#exec-once = ${launch_cmds[$idx]}/exec-once = ${launch_cmds[$idx]}/" "$conf"

    hyprctl reload &>/dev/null || true
}

# Show menu
show_menu() {
    local current="$1"

    echo ""
    echo "Select a shell to switch to:"
    echo ""

    for i in "${!shells[@]}"; do
        if [[ "${shells[$i]}" == "$current" ]]; then
            echo "$((i + 1))) ${GREEN}* ${names[$i]} (active)${NC}"
        else
            echo "$((i + 1))) ${names[$i]}"
        fi
    done
    echo ""
}

main "$@"
